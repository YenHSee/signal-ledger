# Copy to .env and fill in real values:
#   cp .env.example .env

# ── Database (required) ──────────────────────────────────────────────────────
# Local docker compose maps Postgres to host port 5433 (see root docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=stock_analyst

# ── Cloudflare KV (required for ETL — caches Yahoo fundamentals) ─────────────
CF_ACCOUNT_ID=
CF_NAMESPACE_ID=
CF_API_TOKEN=

# ── News (optional — STEP 5 skipped if unset) ───────────────────────────────
FINNHUB_API_KEY=

# ── LLM for report generation (main.py — pick one provider) ─────────────────
MODEL_PROVIDER=ollama

# OpenAI (ModelTier.SMART — gpt-4o)
OPENAI_API_KEY=

# DeepSeek (ModelTier.NORMAL — deepseek-chat)
DEEPSEEK_API_KEY=

# Ollama runs locally; no key needed. Default model: qwen2.5:7b

# ── Legacy / unused by daily ETL ────────────────────────────────────────────
# ALPHA_VANTAGE_API_KEY=
# PERPLEXITY_API_KEY=
